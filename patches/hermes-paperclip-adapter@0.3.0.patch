+function cfgLooseStringArray(v) {
+    if (Array.isArray(v) && v.every((i) => typeof i === "string")) {
+        return v;
+    }
+    if (typeof v === "string" && v.trim().length > 0) {
+        return v
+            .split(",")
+            .map((item) => item.trim())
+            .filter((item) => item.length > 0);
+    }
+    return undefined;
+}
+function normalizeModelList(values) {
+    const seen = new Set();
+    const normalized = [];
+    for (const value of values) {
+        if (typeof value !== "string")
+            continue;
+        const trimmed = value.trim();
+        if (!trimmed || seen.has(trimmed))
+            continue;
+        seen.add(trimmed);
+        normalized.push(trimmed);
+    }
+    return normalized;
+}
+function isDisallowedModel(model) {
+    const normalized = model.trim().toLowerCase();
+    return normalized.startsWith("claude") || normalized.startsWith("anthropic/claude");
+}
+function resolveModelCandidates(config) {
+    const configuredModel = cfgString(config.model);
+    const ladder = MODEL_LADDER_CONFIG_KEYS.flatMap((key) => cfgLooseStringArray(config[key]) ?? []);
+    const candidates = normalizeModelList([
+        ...(configuredModel && !isDisallowedModel(configuredModel) ? [configuredModel] : []),
+        ...ladder.filter((model) => !isDisallowedModel(model)),
+    ]);
+    return candidates.length > 0 ? candidates : [DEFAULT_MODEL];
+}
+function summarizeFailure(text) {
+    if (!text)
+        return "Hermes returned an unknown model execution failure.";
+    const lines = text
+        .split("\n")
+        .map((line) => line.trim())
+        .filter(Boolean);
+    return lines.slice(0, 6).join("\n").slice(0, 1200);
+}
