diff --git a/dist/server/execute.js b/dist/server/execute.js
--- a/dist/server/execute.js
+++ b/dist/server/execute.js
@@ -34,6 +34,20 @@ function cfgStringArray(v) {
     return Array.isArray(v) && v.every((i) => typeof i === "string")
         ? v
         : undefined;
+}
+function cfgSessionId(v) {
+    const value = cfgString(v);
+    if (!value)
+        return undefined;
+    // Hermes prints "Use a session ID from a previous CLI run" when a resume fails.
+    // Older parsing could persist the word "from" as the next session id.
+    if (/^from$/i.test(value))
+        return undefined;
+    // A failed resume can also leave a truncated Hermes timestamp id such as
+    // "20260509_143232_". Never feed that back into --resume.
+    if (/^\d{8}_\d{6}_$/.test(value))
+        return undefined;
+    return value;
 }
