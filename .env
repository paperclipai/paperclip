# API Keys (à configurer dans Coolify)
OPENAI_API_KEY=${OPENAI_API_KEY}
ANTHROPIC_API_KEY=${ANTHROPIC_API_KEY}

# Base de données (Coolify va remplir automatiquement)
DATABASE_URL=${DATABASE_URL}

# Configuration serveur
PORT=3000
SERVE_UI=true

# NextAuth (Coolify va générer automatiquement)
NEXTAUTH_SECRET=${SERVICE_PASSWORD_64_NEXTAUTH}
NEXTAUTH_URL=${SERVICE_FQDN_PAPERCLIP}

# Environnement
NODE_ENV=production
