# .env - Production configuration for Paperclip VPS deployment
# WARNING: This file contains secrets. Never commit to version control.

# Docker Compose Project Name
COMPOSE_PROJECT_NAME=paperclip

# Host IP and Port for local binding (will be ignored if Traefik is used)
HOST_BIND_IP=0.0.0.0
APP_PORT=3100

# PostgreSQL Credentials
POSTGRES_USER=paperclip
POSTGRES_PASSWORD=papertable
POSTGRES_DB=paperclip

# Paperclip Application Configuration
PAPERCLIP_PUBLIC_URL=https://paperclip.carisinternational.com
PAPERCLIP_DEPLOYMENT_MODE=authenticated
PAPERCLIP_DEPLOYMENT_EXPOSURE=public
BETTER_AUTH_SECRET=paperclip-better-auth-secret-key-change-in-production-d3f4ult
TRUST_PROXY=172.19.0.0/16

# Paperclip Internal Configuration (usually leave as is)
SERVE_UI=true
PAPERCLIP_HOME=/paperclip
PAPERCLIP_INSTANCE_ID=default
PAPERCLIP_SECRETS_STRICT_MODE=true

# API Keys for CLIs and Paperclip Adapters
ANTHROPIC_API_KEY=om-7hk48WkYHUjVhwYFND6hRioCmX8cYgDzmitMqvLpM
ANTHROPIC_BASE_URL=https://api.openmodel.ai/v1

OPENAI_API_KEY=om-7hk48WkYHUjVhwYFND6hRioCmX8cYgDzmitMqvLpM

# Claude CLI Configuration
CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1
ANTHROPIC_DEFAULT_OPUS_MODEL=deepseek-v4-flash
ANTHROPIC_DEFAULT_SONNET_MODEL=deepseek-v4-flash
ANTHROPIC_DEFAULT_HAIKU_MODEL=deepseek-v4-flash

# Codex CLI Configuration
CODEX_MODEL_PROVIDER=openmodel
CODEX_MODEL=deepseek-v4-flash
CODEX_MODEL_REASONING_EFFORT=high
CODEX_DISABLE_RESPONSE_STORAGE=true
CODEX_PREFERRED_AUTH_METHOD=apikey
CODEX_OPENMODEL_BASE_URL=https://api.openmodel.ai/v1

# Traefik Configuration (for production deployment)
TRAEFIK_NETWORK=afiacloud-containers
TRAEFIK_CERTRESOLVER=letsencrypt
TRAEFIK_DOMAIN=paperclip.carisinternational.com

# Other potential API keys for Paperclip Adapters (optional)
GEMINI_API_KEY=
GOOGLE_API_KEY=
