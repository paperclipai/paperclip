ить визуально (dialog/dropdown/conditional render)\n\nОпиши в комментарии **точные шаги воспроизведения** (клики, query-params), чтобы CEO мог открыть состояние. Без этого QA_OK не выдаём.\n\n## Subordinate escalation\n\nЕсли застрял — `@CEO` в комментарии с конкретным вопросом (см. правила в AGENTS.md).\n","status":"in_review","priority":"high","assigneeAgentId":"db69a3af-4281-40f9-9612-00d9c9c80315","assigneeUserId":null,"checkoutRunId":null,"executionRunId":null,"executionAgentNameKey":null,"executionLockedAt":null,"createdByAgentId":null,"createdByUserId":"local-board","issueNumber":92,"identifier":"ZAI-92","originKind":"manual","originId":null,"originRunId":null,"originFingerprint":"default","requestDepth":0,"billingCode":null,"assigneeAdapterOverrides":null,"executionPolicy":{"mode":"normal","stages":[{"id":"3e628a7c-b248-4506-bb91-bebe34d01e63","type":"review","participants":[{"id":"4c1c0c48-a941-4468-9fb7-1bfe38e73321","type":"agent","userId":null,"agentId":"db69a3af-4281-40f9-9612-00d9c9c80315"}],"approvalsNeeded":1},{"id":"0fe459c2-4e02-4e4a-a203-3115b5122ace","type":"approval","participants":[{"id":"39a3a5f1-7f0f-4f4f-b8b1-9ad598c150d8","type":"agent","userId":null,"agentId":"db69a3af-4281-40f9-9612-00d9c9c80315"}],"approvalsNeeded":1}],"commentRequired":true},"executionState":{"status":"pending","reviewRequest":null,"currentStageId":"0fe459c2-4e02-4e4a-a203-3115b5122ace","lastDecisionId":"48578c70-0f49-4f17-a390-11c854b8ed86","returnAssignee":{"type":"agent","userId":null,"agentId":"2c35ae09-781d-4a7c-880b-8abd833fd682"},"currentStageType":"approval","completedStageIds":["3e628a7c-b248-4506-bb91-bebe34d01e63"],"currentStageIndex":1,"currentParticipant":{"type":"agent","userId":null,"agentId":"db69a3af-4281-40f9-9612-00d9c9c80315"},"lastDecisionOutcome":"approved"},"executionWorkspaceId":null,"executionWorkspacePreference":null,"executionWorkspaceSettings":null,"startedAt":"2026-05-07T10:13:58.033Z","completedAt":null,"cancelledAt":null,"hiddenAt":null,"c