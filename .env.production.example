# Paperclip production/runtime environment template for ./run.sh
# Copy to .env.production or let ./run.sh create it automatically.

COMPOSE_PROJECT_NAME=paperclip

# Host/app exposure
HOST_BIND_IP=0.0.0.0
APP_PORT=3100

# PostgreSQL
POSTGRES_USER=paperclip
POSTGRES_PASSWORD=CHANGE_ME_DB_PASSWORD
POSTGRES_DB=paperclip

# Paperclip runtime
PAPERCLIP_PUBLIC_URL=http://YOUR_SERVER_IP:3100
PAPERCLIP_DEPLOYMENT_MODE=authenticated
PAPERCLIP_DEPLOYMENT_EXPOSURE=private
BETTER_AUTH_SECRET=CHANGE_ME_AUTH_SECRET
SERVE_UI=true
PAPERCLIP_HOME=/paperclip
PAPERCLIP_INSTANCE_ID=default
PAPERCLIP_SECRETS_STRICT_MODE=true

# Optional provider credentials
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GOOGLE_API_KEY=
