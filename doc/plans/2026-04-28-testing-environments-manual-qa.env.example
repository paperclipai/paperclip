# Copy this file to an untracked local path, fill in real values, and export it
# before starting Paperclip:
#
#   set -a
#   source /path/to/testing-environments-manual-qa.env
#   set +a

PAPERCLIP_BASE_URL=http://localhost:3100

QA_COMPANY_NAME=Environment QA
QA_PROJECT_NAME=Environment Matrix QA
QA_PROJECT_WORKSPACE_CWD=/absolute/path/to/paperclip-env-matrix-workspace

QA_SSH_ENV_NAME=QA SSH
QA_SSH_HOST=
QA_SSH_PORT=22
QA_SSH_USERNAME=
QA_SSH_REMOTE_WORKSPACE_PATH=
QA_SSH_KNOWN_HOSTS=
QA_SSH_STRICT_HOST_KEY_CHECKING=true

QA_E2B_PLUGIN_PACKAGE=@paperclipai/plugin-e2b
QA_E2B_ENV_NAME=QA E2B
QA_E2B_TEMPLATE=base
QA_E2B_TIMEOUT_MS=300000
QA_E2B_REUSE_LEASE=false

# Paperclip's E2B plugin can read this directly from the host environment if
# you leave the environment form apiKey field blank.
E2B_API_KEY=

# Some adapters use CLI login state instead of env-var auth, but keeping the
# provider keys in one operator file still makes setup repeatable.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GOOGLE_API_KEY=

# Used in issue bodies and expected file contents for one QA pass.
QA_ISSUE_MARKER_DATE=2026-04-28
QA_ISSUE_MARKER_ROOT=manual-qa/environment-matrix
