# syntax=harbor.blockcast.net/dockerfile/dockerfile:1.20
#
# paperclip-agent base image — extends the paperclip server image with the
# build/devops toolchain that technical agents need to actually do work in
# their workspace pods. Mirrors the proxmox-infra devbox VM template
# (scripts/05-languages.sh + 03-k8s-tools.sh + 02-docker.sh).
#
# Pair with a `docker:dind` sidecar in the agent Job spec — the docker CLI
# below talks to that sidecar over /var/run/docker.sock (shared via
# emptyDir). `kind` then spins up nested k8s clusters on top of dind for
# any agent workflow that uses magma/cdn/fab/k8s_ops.py (which detects
# `kind-kind` context out of the box).
#
# Tagged separately as `paperclip-agent:sha-…-k8s-vendored` so the heavy
# toolchain doesn't bloat the paperclip-server image.

ARG BASE_IMAGE=harbor.blockcast.net/paperclip/paperclip:latest-k8s-vendored
FROM ${BASE_IMAGE}

USER root

# Build essentials + unzip (kubelogin ships as a zip)
# chromium runtime libs (BLO-3663) — required for headless browser / Playwright / screenshot capabilities
# Canonical list from `npx playwright install-deps chromium --dry-run`
# Cypress runtime libs (BLO-6436) — libgtk-3-0t64 + libxss1 + libxtst6 +
# xauth + libnotify4 cover what Cypress 14's Electron runtime needs on top
# of the Playwright set (Playwright bundles Chromium and skips these).
RUN apt-get update \
  && apt-get install -y --no-install-recommends \
        build-essential pkg-config libssl-dev unzip \
        libasound2t64 libatk-bridge2.0-0t64 libatk1.0-0t64 libatspi2.0-0t64 \
        libcairo2 libcups2t64 libdbus-1-3 libdrm2 libgbm1 \
        libglib2.0-0t64 libnspr4 libnss3 libpango-1.0-0 \
        libx11-6 libxcb1 libxcomposite1 libxdamage1 libxext6 \
        libxfixes3 libxkbcommon0 libxrandr2 xvfb \
        libgtk-3-0t64 libxss1 libxtst6 xauth libnotify4 \
        fonts-noto-color-emoji fonts-unifont libfontconfig1 libfreetype6 \
        xfonts-scalable fonts-liberation fonts-ipafont-gothic \
        fonts-wqy-zenhei fonts-tlwg-loma-otf fonts-freefont-ttf \
  && rm -rf /var/lib/apt/lists/*

# ---------------------------------------------------------------------------
# Languages
# ---------------------------------------------------------------------------

# Go (matches devbox 05-languages.sh)
ARG GO_VERSION=1.24.4
RUN curl -fsSL "https://go.dev/dl/go${GO_VERSION}.linux-amd64.tar.gz" \
  | tar -C /usr/local -xzf - \
  && ln -s /usr/local/go/bin/go /usr/local/bin/go \
  && ln -s /usr/local/go/bin/gofmt /usr/local/bin/gofmt

# Rust (system-wide, matches devbox)
ENV RUSTUP_HOME=/usr/local/rustup CARGO_HOME=/usr/local/cargo
RUN curl -fsSL https://sh.rustup.rs \
  | sh -s -- -y --no-modify-path --default-toolchain stable \
  && for b in /usr/local/cargo/bin/*; do ln -sf "$b" /usr/local/bin/; done

# Python dev headers (node:lts-trixie-slim ships python3 but no -dev/venv)
RUN apt-get update \
  && apt-get install -y --no-install-recommends python3-pip python3-venv python3-dev \
  && rm -rf /var/lib/apt/lists/*

# Java runtime (BLO-4469 / BLO-1446) — shaka-player's `build/all.py` compiles
# the Shaka MSF bundle with the Closure Compiler, a Java JAR, and probes
# `java -version` (build/compiler.py:_get_java_major_version) at bootstrap;
# without a JRE an agent rebuilding public/shaka-player.compiled.js fails on
# the first step. Headless OpenJDK only — agents run the Closure JAR, not a
# desktop JVM. Karma browser tests (build/test.py) still drive the remote-CDP
# browser seam (agent-browser / CCROTATE_DESIGNER_LEASE_HOST), so no Chrome is
# bundled here — that stays a deliberate non-goal of this image.
RUN apt-get update \
  && apt-get install -y --no-install-recommends default-jre-headless \
  && rm -rf /var/lib/apt/lists/* \
  && java -version

# ---------------------------------------------------------------------------
# Container + cluster tooling
# ---------------------------------------------------------------------------

# Docker CLI only — daemon is provided by a `dind` sidecar in the agent Job.
RUN install -m 0755 -d /etc/apt/keyrings \
  && curl -fsSL https://download.docker.com/linux/debian/gpg \
       -o /etc/apt/keyrings/docker.asc \
  && chmod a+r /etc/apt/keyrings/docker.asc \
  && echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/docker.asc] https://download.docker.com/linux/debian $(. /etc/os-release && echo $VERSION_CODENAME) stable" \
       > /etc/apt/sources.list.d/docker.list \
  && apt-get update \
  && apt-get install -y --no-install-recommends \
       docker-ce-cli docker-buildx-plugin docker-compose-plugin \
  && rm -rf /var/lib/apt/lists/*

ARG KUBECTL_VERSION=v1.31.4
RUN curl -fsSL "https://dl.k8s.io/release/${KUBECTL_VERSION}/bin/linux/amd64/kubectl" \
       -o /usr/local/bin/kubectl \
  && chmod +x /usr/local/bin/kubectl

ARG HELM_VERSION=v3.20.0
RUN curl -fsSL "https://get.helm.sh/helm-${HELM_VERSION}-linux-amd64.tar.gz" \
  | tar -C /tmp -xzf - \
  && mv /tmp/linux-amd64/helm /usr/local/bin/helm \
  && rm -rf /tmp/linux-amd64

# kind (in-Docker Kubernetes) — magma/cdn/fab/k8s_ops.py detects the
# `kind-kind` context as a first-class local runtime alongside minikube.
ARG KIND_VERSION=v0.24.0
RUN curl -fsSL "https://kind.sigs.k8s.io/dl/${KIND_VERSION}/kind-linux-amd64" \
       -o /usr/local/bin/kind \
  && chmod +x /usr/local/bin/kind

# kubelogin (kubectl-oidc_login) — matches devbox 03-k8s-tools.sh; needed
# for OIDC-authed kubeconfigs that paperclip-0 will start handing to agents
# once the kubernetes-admin@kubernetes context is rotated out.
ARG KUBELOGIN_VERSION=v1.30.1
RUN curl -fsSL "https://github.com/int128/kubelogin/releases/download/${KUBELOGIN_VERSION}/kubelogin_linux_amd64.zip" \
       -o /tmp/kubelogin.zip \
  && unzip -d /tmp /tmp/kubelogin.zip \
  && mv /tmp/kubelogin /usr/local/bin/kubectl-oidc_login \
  && chmod +x /usr/local/bin/kubectl-oidc_login \
  && rm -f /tmp/kubelogin.zip /tmp/LICENSE

# ---------------------------------------------------------------------------
# Designer + browser automation CLIs (ccrotate-designer-lease)
# ---------------------------------------------------------------------------

# Bake designer + agent-browser globally at pinned versions. Drops the
# 'npx -y' supply-chain dependency from the designer-loop skill (codex F6).
# When CCROTATE_DESIGNER_LEASE_HOST is set, agents in this image use the
# baked CLIs against a remote Chrome via CDP — no Chrome bundling required.
ARG DESIGNER_VERSION=0.3.6
ARG AGENT_BROWSER_VERSION=0.27.0
RUN npm i -g \
    @pro-vi/designer@${DESIGNER_VERSION} \
    agent-browser@${AGENT_BROWSER_VERSION} \
  && which designer && which agent-browser

# ---------------------------------------------------------------------------
# Protocol Buffers (BLO-5492)
# ---------------------------------------------------------------------------
# magma's orc8r/cloud/go genpb step needs `protoc` + protoc-gen-go +
# protoc-gen-go-grpc. Pinned versions match the magma go.mod toolchain
# (google.golang.org/protobuf v1.34+, google.golang.org/grpc v1.65+).
ARG PROTOC_VERSION=27.2
ARG PROTOC_GEN_GO_VERSION=v1.34.2
ARG PROTOC_GEN_GO_GRPC_VERSION=v1.4.0
RUN curl -fsSL "https://github.com/protocolbuffers/protobuf/releases/download/v${PROTOC_VERSION}/protoc-${PROTOC_VERSION}-linux-x86_64.zip" \
       -o /tmp/protoc.zip \
  && unzip -q /tmp/protoc.zip 'bin/protoc' 'include/*' -d /usr/local \
  && chmod -R a+rX /usr/local/include/google \
  && rm /tmp/protoc.zip \
  && GOBIN=/usr/local/bin /usr/local/go/bin/go install \
       google.golang.org/protobuf/cmd/protoc-gen-go@${PROTOC_GEN_GO_VERSION} \
  && GOBIN=/usr/local/bin /usr/local/go/bin/go install \
       google.golang.org/grpc/cmd/protoc-gen-go-grpc@${PROTOC_GEN_GO_GRPC_VERSION} \
  && rm -rf /root/go /root/.cache \
  && protoc --version \
  && protoc-gen-go --version \
  && protoc-gen-go-grpc --version

# ---------------------------------------------------------------------------
# Self-serve dependency installation (BLO-5492)
# ---------------------------------------------------------------------------
# Agents run as `USER node` below; without sudo they cannot apt-install a
# missing tool when one comes up (terraform, awscli, a new lint binary, …).
# Every gap would otherwise require a Dockerfile.agent rebuild + image roll
# — the structural pattern this issue is fixing.
#
# Sudo is scoped NOPASSWD to package-management commands only — `apt`,
# `apt-get`, `dpkg`, `dpkg-reconfigure`, and `pipx`. Not `sudo bash` /
# `sudo -i`, so the blast radius stays inside Debian's package
# infrastructure. Agent code that wants arbitrary root must change the
# Dockerfile.
#
# npm-global prefix is moved to /home/node/.npm-global so `npm i -g`
# from the node user also works without sudo. The existing root-installed
# globals (designer, agent-browser) remain under /usr/local/bin and stay
# on PATH; the new prefix is prepended to PATH so user installs win on
# name collisions.
RUN apt-get update \
  && apt-get install -y --no-install-recommends sudo pipx \
  && rm -rf /var/lib/apt/lists/* \
  && install -m 0440 /dev/null /etc/sudoers.d/node-pkg-install \
  && printf 'node ALL=(root) NOPASSWD: /usr/bin/apt, /usr/bin/apt-get, /usr/bin/dpkg, /usr/bin/dpkg-reconfigure, /usr/bin/pipx\n' \
       > /etc/sudoers.d/node-pkg-install \
  && chmod 0440 /etc/sudoers.d/node-pkg-install \
  && visudo -c -f /etc/sudoers.d/node-pkg-install \
  && install -d -o node -g node -m 0755 /home/node/.npm-global /home/node/.npm-cache
ENV NPM_CONFIG_PREFIX=/home/node/.npm-global
ENV NPM_CONFIG_CACHE=/home/node/.npm-cache
ENV PATH=/home/node/.npm-global/bin:$PATH

# ---------------------------------------------------------------------------
# Blockcast FFmpeg with the moq_mmt muxer (MMTP container + RaptorQ FEC) — BLO-8717
# ---------------------------------------------------------------------------
# The CI-prepared build from Harbor, NOT stock apt ffmpeg (which has no moq_mmt
# muxer). Lets technical agents generate/verify MMTP captures and run live-publish
# E2E in their workspace pods instead of towering on in-pod toolchain provisioning
# (BLO-8707). /usr/local/bin precedes /usr/bin on PATH, so this shadows any stock
# ffmpeg already present.
#
# Source host is registry.blockcast.net (BLO-8719), the LAN-local cache registry
# the self-hosted runner can reach (docker-agent.yml logs in with the same
# HARBOR_USERNAME/HARBOR_PASSWORD pair). NOT harbor.blockcast.net — ffmpeg-publisher
# is not replicated there, so a harbor COPY 404s.
#
# Use the floating :stable tag, NOT a digest pin. pim-multicast-gateway's
# docker-build.yml pushes ffmpeg-publisher to BOTH registry.blockcast.net and
# docker.io/blockcast/ffmpeg-publisher (external: true), but its registry.blockcast.net
# push intermittently 503s and is retried independently (see that workflow's login
# retry loop). As a result an individual build's manifest digest is only guaranteed
# on docker.io — e.g. sha256:cba732a2…, which e2e-codec-matrix.yml pulls via its
# FF_IMAGE (docker.io) fallback, not FF_IMAGE_LOCAL — and is NOT guaranteed on the
# LAN cache. Pinning that digest here 404'd on registry.blockcast.net (BLO-8719).
# :stable is a moving pointer to the latest *successful* registry.blockcast.net push,
# so it resolves on the LAN cache without needing Docker Hub credentials in this repo.
# Reproducibility trade-off accepted (owner note on BLO-8717: ":stable tracks latest;
# pin @sha256 only if you want reproducible agent-image builds").
# The agent base image is Debian trixie, but ffmpeg-publisher is built on
# debian:bookworm-slim (FFmpeg/Dockerfile: `FROM debian:bookworm-slim AS runtime`),
# so its ffmpeg binary is dynamically linked against the bookworm codec sonames.
# Most are soname-stable on trixie (libx264.so.164, libaom.so.3, libopus.so.0,
# libfreetype.so.6, libharfbuzz.so.0, libfontconfig.so.1, libgomp.so.1,
# libssl.so.3) and resolve from trixie apt. Two drifted: trixie ships
# libx265.so.215 / libvpx.so.9, not the .199 / .7 the binary needs (apt fails
# with "Unable to locate package libx265-199 / libvpx7" — BLO-8790). Copy those
# two .so files straight from the publisher image so the binary's ABI is
# satisfied regardless of the base distro's codec versions. libnuma1 is
# libx265.so.199's transitive dep and is not otherwise pulled in.
RUN apt-get update \
  && apt-get install -y --no-install-recommends \
       libx264-164 libaom3 libopus0 libnuma1 \
       libfreetype6 libharfbuzz0b libfontconfig1 libgomp1 libssl3 \
  && rm -rf /var/lib/apt/lists/*
COPY --from=registry.blockcast.net/blockcast/pim-multicast-gateway/ffmpeg-publisher:stable \
     /usr/lib/x86_64-linux-gnu/libx265.so.199* /usr/lib/x86_64-linux-gnu/
COPY --from=registry.blockcast.net/blockcast/pim-multicast-gateway/ffmpeg-publisher:stable \
     /usr/lib/x86_64-linux-gnu/libvpx.so.7*   /usr/lib/x86_64-linux-gnu/
RUN ldconfig
COPY --from=registry.blockcast.net/blockcast/pim-multicast-gateway/ffmpeg-publisher:stable \
     /usr/local/bin/ffmpeg  /usr/local/bin/ffmpeg
COPY --from=registry.blockcast.net/blockcast/pim-multicast-gateway/ffmpeg-publisher:stable \
     /usr/local/bin/ffprobe /usr/local/bin/ffprobe
RUN ffmpeg -hide_banner -muxers 2>&1 | grep -qE '(^|[[:space:]])moq_mmt([[:space:]]|$)' \
  || (echo 'ERROR: moq_mmt muxer missing from copied ffmpeg' && exit 1)

# Hand back to the non-root `node` user — paperclip's docker-entrypoint.sh
# runs as that uid (matches the host user mapping established in the base
# image's USER_UID/USER_GID args).
USER node
