# Copy to .env (or define no Dockploy → Environment) e preencha.
# Não commitar valores reais. Rotacione qualquer chave que tenha vazado.

# Postgres existente — usuário/senha/host/porta/db
DATABASE_URL=postgres://paperclip:TROQUE_AQUI@databases-postgres-cypdtq:5432/paperclip

# URL pública do paperclip (HTTPS via reverse proxy do Dockploy)
PAPERCLIP_PUBLIC_URL=https://pc.bidu.guru

# Segredo do BetterAuth — 32 bytes base64 (openssl rand -base64 32)
BETTER_AUTH_SECRET=TROQUE_AQUI

# Z.AI Coding Plan API key (https://z.ai → Console → API Keys)
ZAI_API_KEY=TROQUE_AQUI
