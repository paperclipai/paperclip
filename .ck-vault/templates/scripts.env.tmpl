# scripts.env — secrets for /workspace helper scripts ONLY.
# Read by the scripts (via lib-secrets.mjs), NOT exposed to the agent's chat/LLM context.
# Mounted read-only into the container at /run/scripts.env. Keep chmod 600.
# Add a line for ANY key a script needs (Browserbase, email, future APIs).
#
# Populate the Browserbase values once (run on the server):
#   grep -E '^BROWSERBASE_(API_KEY|PROJECT_ID)=' ~/divino-agent/hermes/.env >> ~/divino-agent/secrets/scripts.env
#
# ---- add KEY=VALUE lines below this line ----
BROWSERBASE_API_KEY={{divino-browserbase-api-key}}
BROWSERBASE_PROJECT_ID={{divino-browserbase-project-id}}
# Marketplace logins (materialized from the vault; posting scripts read these via secret()).
TUTTI_EMAIL=info@divinocigars.ch
TUTTI_PASS={{divino-tutti}}
ANIBIS_EMAIL=info@divinocigars.ch
ANIBIS_PASS={{divino-anibis}}
LAPULGA_EMAIL=alanjohn.c@hotmail.com
LAPULGA_PASS={{divino-lapulga}}
