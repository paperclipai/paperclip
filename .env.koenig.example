# Koenig AI Academy — Centralized Secrets File
#
# Fill in each value below. After saving, run:
#   ./scripts/sync-secrets.sh
#
# The script reads this file, creates each secret in Paperclip's encrypted
# store (~/.paperclip Postgres), and binds each to the agents that need it.
# Never commit this file with real values — it's gitignored.

# === Web search / research ===
TAVILY_API_KEY=
# Get at: https://app.tavily.com (free tier 1000 calls/mo)

XAI_API_KEY=
# Get at: https://console.x.ai (researcher-community uses heavily)

# === Email approvals (G4 to Vardaan) ===
RESEND_API_KEY=
# Get at: https://resend.com/api-keys (free tier 3k emails/mo)

# === GitHub for engineering harness ===
GH_TOKEN=
# Fine-grained PAT: https://github.com/settings/tokens?type=beta
# Repos: Koenig-Solutions-Private-Limited/learnovaBeast + koenig-ai-org
# Scopes: contents:write, pull-requests:write, issues:write, workflows (read)

# === Convex agent API (after Phase R8 backend lands; can be blank now) ===
ACADEMY_AGENT_API_KEY=
# Generated by R8 backend; bearer used by content-author for agentApi calls

# === NotebookLM (slide+audio producer) — set after `notebooklm login` ===
# notebooklm-py uses ~/.notebooklm/storage_state.json (not env), so nothing here.
# Just run: notebooklm login

# === Open-Notebook fallback (already running locally on :5055) ===
OPEN_NOTEBOOK_API_KEY=local-dev
# Optional: only needed if you put auth in front of the local container

# === Vercel (for academy.kspl.tech deploy) ===
VERCEL_TOKEN=
# Get at: https://vercel.com/account/tokens (create new "Full account" token).
# Used non-interactively by `vercel deploy` and CI later.

# === V2 / future (leave blank for V1) ===
SLACK_WEBHOOK_URL=
TEAMS_WEBHOOK_URL=
