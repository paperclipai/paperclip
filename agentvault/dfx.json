{
  "canisters": {
    "agent_vault": {
      "main": "canister/agent.mo",
      "initialization_values": {
        "wasm_memory_limit": 67108864
      }
    },
    "memory_repo": {
      "main": "canister/memory-repo.mo",
      "initialization_values": {
        "wasm_memory_limit": 67108864
      }
    }
  },
  "networks": {
    "local": {
      "bind": "127.0.0.1:8000",
      "type": "ephemeral"
    },
    "private": {
      "bind": "127.0.0.1:8080",
      "type": "ephemeral",
      "replica": {
        "subnet_type": "system"
      }
    },
    "ic": {
      "providers": ["https://ic0.app"],
      "type": "persistent"
    }
  }
}
