# SSO Docker Compose environment variables
# Copy to .env in the docker/ directory before running docker-compose.sso.yml

# Better Auth secret (any random string, used for session signing)
BETTER_AUTH_SECRET=change-me-to-a-random-secret

# Keycloak admin console: http://localhost:8080
# Keycloak admin credentials: admin / admin
#
# Pre-configured test users in the "paperclip" realm:
#   admin@paperclip.local / admin
#   operator@paperclip.local / operator
#
# Paperclip UI: http://localhost:3100
# Click "Keycloak SSO" on the login page to authenticate via Keycloak.
#
# IMPORTANT: The Keycloak issuer URL in PAPERCLIP_SSO_PROVIDERS uses the
# Docker-internal hostname "keycloak:8080". For browser redirects to work,
# make sure the Keycloak port (8080) is exposed to the host.
