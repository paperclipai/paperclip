# AWS ECS Fargate deployment environment
# Copy to .env.aws and fill in values before deploying
#
# Secrets (DATABASE_URL, BETTER_AUTH_SECRET, ANTHROPIC_API_KEY, OPENAI_API_KEY,
# GITHUB_TOKEN) are injected via AWS Secrets Manager — do NOT set them here.

# Deployment mode
VALADRIEN_OS_DEPLOYMENT_MODE=authenticated
VALADRIEN_OS_DEPLOYMENT_EXPOSURE=public
VALADRIEN_OS_PUBLIC_URL=https://valadrien-os.example.com

# Server
HOST=0.0.0.0
PORT=3100
NODE_ENV=production
SERVE_UI=true

# ValAdrien OS paths
VALADRIEN_OS_HOME=/valadrien-os
VALADRIEN_OS_INSTANCE_ID=default
VALADRIEN_OS_CONFIG=/valadrien-os/instances/default/config.json

# Auto-apply migrations on startup
VALADRIEN_OS_MIGRATION_AUTO_APPLY=true

# Enable heartbeat scheduler for remote agents
HEARTBEAT_SCHEDULER_ENABLED=true

# Post-deploy hardening (uncomment after first user signs up)
# VALADRIEN_OS_AUTH_DISABLE_SIGN_UP=true
