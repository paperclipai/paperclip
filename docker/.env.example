# Copy this file to docker/.env and fill in the values before running docker compose.
# docker/.env is gitignored — never commit real credentials.

# Paperclip API key for the telegram-bot, watchdog, and dashboard services.
# Generate a new key in the Paperclip admin panel and set it here.
PAPERCLIP_TGBOT_API_KEY=

# Your Paperclip company ID (visible in the Paperclip admin panel).
PAPERCLIP_COMPANY_ID=

# Agent ID of the CTO agent in your Paperclip company.
PAPERCLIP_CTO_AGENT_ID=

# Telegram chat ID to send notifications to.
ANGEL_CHAT_ID=

# Telegram bot token (from @BotFather).
TELEGRAM_BOT_TOKEN=

# Auth secret for Better Auth (generate with: openssl rand -base64 32).
BETTER_AUTH_SECRET=

# Optional: public URL of the Paperclip server (default: http://localhost:3100).
# PAPERCLIP_PUBLIC_URL=https://your-domain.com

# Optional: deploy token for the dashboard service.
# DEPLOY_TOKEN=

# Optional: Gmail credentials for watchdog alert emails.
# GMAIL_USER=you@gmail.com
# GMAIL_APP_PASSWORD=
# ALERT_EMAIL_TO=you@gmail.com
