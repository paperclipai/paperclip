# Copy this file to .paperclip/.env and fill in real values.
# Never commit .paperclip/.env — it contains secrets.

# External PostgreSQL connection string
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require

# Auth secrets — generate strong random values
BETTER_AUTH_SECRET=change-me-generate-random-secret
PAPERCLIP_AGENT_JWT_SECRET=change-me-generate-random-secret

# UI serving — false for dev (Vite serves UI), true for production
SERVE_UI=false

# SharePoint / MS Graph credentials
SHAREPOINT_TENANT_ID=your-azure-tenant-id
SHAREPOINT_CLIENT_ID=your-sharepoint-app-client-id
SHAREPOINT_CLIENT_SECRET=your-sharepoint-client-secret
SHAREPOINT_SITE_URL=https://yourtenant.sharepoint.com/sites/YourSite

# Outlook MCP credentials
OUTLOOK_CLIENT_ID=your-outlook-app-client-id
OUTLOOK_CLIENT_SECRET=your-outlook-client-secret
OUTLOOK_MAILBOX=user@yourdomain.com

# Apify (web search / actor runner)
APIFY_API_KEY=your-apify-api-key

# Resend — outbound bulk/marketing email
RESEND_API_KEY=your-resend-api-key
