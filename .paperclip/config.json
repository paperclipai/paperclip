{
  "$meta": {
    "version": 1,
    "updatedAt": "2026-04-26T00:00:00.000Z",
    "source": "configure"
  },
  "database": {
    "mode": "postgres",
    "backup": {
      "enabled": false,
      "intervalMinutes": 60,
      "retentionDays": 7,
      "dir": ".paperclip/data/backups"
    }
  },
  "logging": {
    "mode": "file",
    "logDir": ".paperclip/logs"
  },
  "server": {
    "deploymentMode": "authenticated",
    "exposure": "private",
    "bind": "0.0.0.0",
    "host": "0.0.0.0",
    "port": 3100,
    "allowedHostnames": [],
    "serveUi": true
  },
  "auth": {
    "baseUrlMode": "auto",
    "disableSignUp": true
  },
  "telemetry": {
    "enabled": true
  },
  "storage": {
    "provider": "local_disk",
    "localDisk": {
      "baseDir": ".paperclip/data/storage"
    },
    "s3": {
      "bucket": "paperclip",
      "region": "us-east-1",
      "prefix": "",
      "forcePathStyle": false
    }
  },
  "secrets": {
    "provider": "local_encrypted",
    "strictMode": false,
    "localEncrypted": {
      "keyFilePath": ".paperclip/secrets/master.key"
    }
  }
}
