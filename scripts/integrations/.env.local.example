# YouTube Shorts Pipeline — credentials template
# Copy to .env.local and fill in your values.
# Values here are loaded automatically when the pipeline runs.
# .env.local is gitignored; never commit real credentials.

# ── Script generation ─────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# ── Voiceover (ElevenLabs) ────────────────────────────────────────────────────
ELEVENLABS_API_KEY=...
# ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM   # Rachel (default)
# ELEVENLABS_MODEL=eleven_multilingual_v2

# ── Stock footage (Pexels — optional) ─────────────────────────────────────────
# PEXELS_API_KEY=...

# ── Affiliate tracking (Refersion — optional) ─────────────────────────────────
# REFERSION_API_KEY=...
# REFERSION_BASE_URL=https://track.yoursite.com/ref

# ── YouTube upload ────────────────────────────────────────────────────────────
# One-time setup: download youtube_client_secret.json from Google Cloud Console,
# then run: python youtube_auth.py
YOUTUBE_PRIVACY=private    # private | unlisted | public
# YOUTUBE_CLIENT_SECRET_FILE=secrets/youtube_client_secret.json
# YOUTUBE_TOKEN_FILE=secrets/youtube_token.json

# ── Airtable performance tracking ─────────────────────────────────────────────
# One-time setup: run create-schema to get AIRTABLE_BASE_ID
AIRTABLE_API_KEY=pat...
AIRTABLE_WORKSPACE_ID=wsp...
AIRTABLE_BASE_ID=app...
# AIRTABLE_TABLE=Videos

# ── Opus Clip (optional) ──────────────────────────────────────────────────────
# OPUS_CLIP_API_KEY=...

# ── Supabase — email_waitlist attribution tracking ────────────────────────────
# Get from: Supabase dashboard → your project → Settings → API
# SUPABASE_URL is the "Project URL" (e.g. https://xxxx.supabase.co)
# SUPABASE_ANON_KEY is the public anon key — embed in landing page HTML (safe, client-side)
# SUPABASE_SERVICE_KEY is the service_role key — server/script use only, never expose publicly
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=eyJ...         # public — paste into REPLACE_WITH_SUPABASE_ANON_KEY in each landing page HTML
SUPABASE_SERVICE_KEY=eyJ...      # private — used by subscriber_report.py only

# Required table (run once in Supabase SQL editor):
#   CREATE TABLE IF NOT EXISTS email_waitlist (
#     id          uuid PRIMARY KEY DEFAULT gen_random_uuid(),
#     email       text NOT NULL,
#     campaign_id text,
#     utm_source  text,
#     utm_medium  text,
#     utm_campaign text,
#     page        text,
#     created_at  timestamptz NOT NULL DEFAULT now()
#   );
#   -- Allow anonymous inserts (landing pages write without auth):
#   ALTER TABLE email_waitlist ENABLE ROW LEVEL SECURITY;
#   CREATE POLICY "anon insert" ON email_waitlist FOR INSERT TO anon WITH CHECK (true);

# ── Resend — transactional email ──────────────────────────────────────────────
# Phase 1 key was send-only. Upgrade to full-access in the Resend dashboard:
#   resend.com → API Keys → create new key with "Full access" permission
# The full-access key lets subscriber_report.py pull contact lists as an attribution fallback.
RESEND_API_KEY=re_...
