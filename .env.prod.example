# Produção — copie para .env e preencha os valores obrigatórios
# cp .env.prod.example .env

# ─── Obrigatórios ────────────────────────────────────────────────────────────

# URL pública da instância (ex: https://tocadaia.exemplo.com.br)
PAPERCLIP_PUBLIC_URL=https://sua-url.exemplo.com.br

# Segredo de autenticação — gere com: openssl rand -hex 32
BETTER_AUTH_SECRET=

# Senha do banco de dados — gere com: openssl rand -hex 16
DB_PASSWORD=

# ─── APIs de IA (ao menos uma obrigatória para agentes funcionarem) ──────────

ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ─── Opcionais ───────────────────────────────────────────────────────────────

# Imagem do app (padrão: imagem pré-compilada do ghcr.io)
# APP_IMAGE=ghcr.io/connect-distribuidora/toca-da-ia:latest

# Portas HTTP/HTTPS do nginx (padrão: 80 e 443)
# HTTP_PORT=80
# HTTPS_PORT=443

# Modo de deployment
# PAPERCLIP_DEPLOYMENT_MODE=authenticated
# PAPERCLIP_DEPLOYMENT_EXPOSURE=private
