# ==========================================
# PAPERCLIP PRODUCTION CONFIGURATION
# ==========================================
# IMPORTANT: Never commit actual secrets to git!
# Copy this file to .env.prod and fill in real values

# === DATABASE ===
DB_USER=paperclip_prod
DB_PASSWORD=generate-with-openssl-rand-base64-32
DB_NAME=paperclip_prod

# === AUTHENTICATION ===
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=generate-with-openssl-rand-base64-32

# === DEPLOYMENT ===
DEPLOYMENT_MODE=authenticated
DEPLOYMENT_EXPOSURE=private

# === PUBLIC ACCESS ===
# Must match your domain + https
PUBLIC_URL=https://paperclip.yourdomain.com

# === LOGGING ===
LOG_LEVEL=info

# === OPTIONAL: AWS S3 ===
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=paperclip-prod-files

# === OPTIONAL: AGENT API KEYS ===
# CLAUDE_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=...
