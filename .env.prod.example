# Production — copy to .env and fill in required values
# cp .env.prod.example .env

# ─── Required ────────────────────────────────────────────────────────────────

# Public URL for this instance (e.g. https://paperclip.example.com)
PAPERCLIP_PUBLIC_URL=https://your-domain.example.com

# Authentication secret — generate with: openssl rand -hex 32
BETTER_AUTH_SECRET=

# Database password — generate with: openssl rand -hex 16
DB_PASSWORD=

# Redis password — generate with: openssl rand -hex 16
REDIS_PASSWORD=

# ─── AI APIs (at least one required for agents to work) ──────────────────────

ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ─── Optional ────────────────────────────────────────────────────────────────

# App image (default: build locally with APP_IMAGE=paperclip:local)
# APP_IMAGE=paperclip:local

# HTTP/HTTPS ports for nginx (default: 80 and 443)
# HTTP_PORT=80
# HTTPS_PORT=443

# Deployment mode
# PAPERCLIP_DEPLOYMENT_MODE=authenticated
# PAPERCLIP_DEPLOYMENT_EXPOSURE=private
