# Sandbox environment variables — mirror of Railway sandbox service config
# Copy this file to .env.sandbox (git-ignored) and fill in real values.
# These vars must also be set on the Railway sandbox service (dashboard or CLI).
#
# Usage (local):
#   cp .env.sandbox.example .env.sandbox
#   # edit .env.sandbox with real values
#   source .env.sandbox && npm run dev

# ── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=sandbox
PORT=3100

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=

# ── Auth / Secrets ────────────────────────────────────────────────────────────
SESSION_SECRET=

# ── Railway-injected (set automatically on Railway, not needed locally) ───────
# RAILWAY_ENVIRONMENT=sandbox
# RAILWAY_SERVICE_NAME=paperclip
# RAILWAY_PROJECT_ID=
