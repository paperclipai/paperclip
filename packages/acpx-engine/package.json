{
  "name": "@paperclipai/acpx-engine",
  "version": "0.3.1",
  "license": "MIT",
  "homepage": "https://github.com/paperclipai/paperclip",
  "bugs": {
    "url": "https://github.com/paperclipai/paperclip/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/paperclipai/paperclip",
    "directory": "packages/acpx-engine"
  },
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./cli": "./src/cli.ts",
    "./constants": "./src/constants.ts",
    "./execute": "./src/execute.ts",
    "./session-codec": "./src/session-codec.ts",
    "./ui": "./src/ui.ts"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      },
      "./cli": {
        "types": "./dist/cli.d.ts",
        "import": "./dist/cli.js"
      },
      "./constants": {
        "types": "./dist/constants.d.ts",
        "import": "./dist/constants.js"
      },
      "./execute": {
        "types": "./dist/execute.d.ts",
        "import": "./dist/execute.js"
      },
      "./session-codec": {
        "types": "./dist/session-codec.d.ts",
        "import": "./dist/session-codec.js"
      },
      "./ui": {
        "types": "./dist/ui.d.ts",
        "import": "./dist/ui.js"
      }
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@paperclipai/adapter-utils": "workspace:*",
    "acpx": "^0.12.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^22.19.21",
    "typescript": "^5.7.3"
  }
}
