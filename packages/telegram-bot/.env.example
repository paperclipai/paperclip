# /etc/paperclip/telegram-bot.env — chmod 600, root:paperclip
# Copy this to /etc/paperclip/telegram-bot.env and fill in real values before
# enabling the systemd unit (docker/systemd/paperclip-tg-bot.service).

# === Required ===
TELEGRAM_BOT_TOKEN=                    # @BotFather token (provided by Динар)
PAPERCLIP_API_URL=http://localhost:3100
PAPERCLIP_BOT_API_KEY=                 # Paperclip admin UI → Service Accounts → New API Key
PAPERCLIP_COMPANY_ID=45cd7642-53da-4c19-82bd-58e8e03cf452
TELEGRAM_BOT_INTERNAL_SECRET=          # `openssl rand -hex 32` — MUST match the same name in /opt/paperclip/.env
TELEGRAM_BOT_INTERNAL_PORT=3110

# === Optional / overrides ===
CEO_AGENT_ID=262a08ea-c041-4af7-a310-e2a0fedc8348
NOTIFIER_INTERVAL_MS=30000
NOTIFIER_DEDUP_FILE=/var/lib/paperclip-tg-bot/seen.json

# === Outbound notifier (Stage 2) ===
# Both DINAR_USER_ID and DINAR_TG_CHAT_ID must be set together to enable outbound
# notifications. Leave both blank on the first deploy (Stage 1: inbound-only).
# After Динар runs /login and links via Profile UI, query auth_users.telegramChatId
# and set both values, then restart paperclip-tg-bot.
DINAR_USER_ID=
DINAR_TG_CHAT_ID=
