{
  "name": "@aiteamcorp/plugin-kitchen-sink-example",
  "version": "0.1.0",
  "description": "Reference plugin that demonstrates the full AiTeamCorp plugin surface area in one package",
  "type": "module",
  "private": true,
  "exports": {
    ".": "./src/index.ts"
  },
  "aiteamcorpPlugin": {
    "manifest": "./dist/manifest.js",
    "worker": "./dist/worker.js",
    "ui": "./dist/ui/"
  },
  "scripts": {
    "prebuild": "node ../../../../scripts/ensure-plugin-build-deps.mjs",
    "build": "tsc && node ./scripts/build-ui.mjs",
    "clean": "rm -rf dist",
    "typecheck": "pnpm --filter @aiteamcorp/plugin-sdk build && tsc --noEmit"
  },
  "dependencies": {
    "@aiteamcorp/plugin-sdk": "workspace:*",
    "@aiteamcorp/shared": "workspace:*"
  },
  "devDependencies": {
    "esbuild": "^0.27.3",
    "@types/node": "^24.6.0",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.7.3"
  },
  "peerDependencies": {
    "react": ">=18"
  }
}
