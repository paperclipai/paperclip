{
  "name": "Luna Voice + Telegram V10",
  "nodes": [
    {
      "parameters": {
        "jsCode": "const u = $input.first().json;\nconst msg = u.message ?? u.edited_message ?? u.channel_post ?? u.edited_channel_post ?? u;\n\nconst chatId = msg?.chat?.id ?? null;\nconst messageId = msg?.message_id ?? null;\n\nconst from = msg?.from ?? {};\nconst tgUserId = from?.id ?? null;\nconst firstName = from?.first_name ?? '';\nconst lastName = from?.last_name ?? '';\nconst tgUsername = from?.username ?? '';\nconst languageCode = from?.language_code ?? '';\nconst username = tgUsername || [firstName, lastName].filter(Boolean).join(' ') || 'Unbekannt';\n\n// Voice (Sprachnachricht) ODER Audio (Datei)\nconst voiceFileId = String(msg?.voice?.file_id || msg?.audio?.file_id || '').trim();\n\nconst inputType = voiceFileId ? 'voice' : 'text';\nconst userText = (msg?.text || msg?.caption || '').trim() || (voiceFileId ? '' : '[Leere Textnachricht]');\n\nreturn [{\n  json: {\n    source: 'telegram',\n    chatId,\n    messageId,\n    tgUserId,\n    firstName,\n    lastName,\n    tgUsername,\n    languageCode,\n    username,\n    inputType,\n    userText,\n    voiceFileId\n  }\n}];"
      },
      "name": "Normalize Telegram Input",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1200,
        704
      ],
      "id": "d53725c6-535e-4215-8e16-a5d576fea99d"
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "{{const chatId = $json.chatId ?? \"NULL\";\nconst tgUserId = $json.tgUserId ?? \"NULL\";\nconst username = String($json.username ?? \"\").replace(/\\'/g, \"\\'\\'\");\nconst firstName = String($json.firstName ?? \"\").replace(/\\'/g, \"\\'\\'\");\nconst lastName = String($json.lastName ?? \"\").replace(/\\'/g, \"\\'\\'\");\nconst tgUsername = String($json.tgUsername ?? \"\").replace(/\\'/g, \"\\'\\'\");\nconst languageCode = String($json.languageCode ?? \"\").replace(/\\'/g, \"\\'\\'\");\nreturn \"WITH updated AS (UPDATE tg_chat_users SET \" +\n  \"tg_user_id = \" + tgUserId + \", \" +\n  \"username = \\'\" + username + \"\\', \" +\n  \"first_name = \\'\" + firstName + \"\\', \" +\n  \"last_name = \\'\" + lastName + \"\\', \" +\n  \"tg_username = \\'\" + tgUsername + \"\\', \" +\n  \"language_code = \\'\" + languageCode + \"\\', \" +\n  \"last_seen_at = now() \" +\n  \"WHERE chat_id = \" + chatId + \" RETURNING 1) \" +\n\"INSERT INTO tg_chat_users (tg_user_id, chat_id, username, first_name, last_name, tg_username, language_code, last_seen_at) \" +\n\"SELECT \" + tgUserId + \", \" + chatId + \", \\'\" + username + \"\\', \\'\" + firstName + \"\\', \\'\" + lastName + \"\\', \\'\" + tgUsername + \"\\', \\'\" + languageCode + \"\\', now() \" +\n\"WHERE NOT EXISTS (SELECT 1 FROM updated);\";}}",
        "options": {}
      },
