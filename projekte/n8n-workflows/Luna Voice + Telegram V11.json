    {
      "parameters": {
        "jsCode": "const o = $json;\n\n// ElevenLabs STT kann je nach Version unterschiedlich heißen:\nconst transcript =\n  o.text ||\n  o.transcript ||\n  o.transcription ||\n  o.data?.text ||\n  o.data?.transcript ||\n  '';\n\nreturn [{\n  json: {\n    ...o,\n    userText: String(transcript || '').trim(),\n    inputType: 'voice'\n  }\n}];\n"
      },
      "name": "Set userText from STT",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2336,
        464
      ],
      "id": "51cfc2c1-d64f-4899-8b68-043ec056b6ba"
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "{{`\nWITH last AS (\n  SELECT role, content, created_at\n  FROM tg_chat_memory\n  WHERE chat_id = ${$json.chatId}\n  ORDER BY created_at DESC\n  LIMIT 12\n)\nSELECT COALESCE(\n  json_agg(json_build_object('role', role, 'content', content) ORDER BY created_at),\n  '[]'::json\n) AS history\nFROM last;\n`}}",
        "options": {}
      },
      "name": "PG Select History",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2,
      "position": [
        1728,
        1168
      ],
      "id": "0f9cd585-4f46-4305-9b53-00184cfb54c3",
      "credentials": {
        "postgres": {
          "id": "0OC4GHQU52Oducxt",
          "name": "Postgres Memory"
        }
      }
    },
    {
      "parameters": {
        "mode": "combine",
        "combinationMode": "mergeByPosition",
        "options": {}
      },
      "name": "Merge Meta + History",
      "type": "n8n-nodes-base.merge",
      "typeVersion": 2,
      "position": [
        1952,
        736
      ],
      "id": "bca2d97d-3325-4db0-8eed-27e648d7ce68"
    },
    {
      "parameters": {
        "jsCode": "let history = $json.history;\n\n// Postgres kann JSON als Objekt/Array oder als String liefern\nif (typeof history === 'string') {\n  try { history = JSON.parse(history); } catch (e) { history = []; }\n}\nif (!Array.isArray(history)) history = [];\n\n// System-Instruktionen (kurz halten, damit weniger \"Meta\" kommt)\nconst systemText =\n  'Du bist ein hilfreicher Assistent. Antworte immer auf Deutsch. Gib nur die Antwort aus, ohne Meta-Sätze.';\n\nconst userName = String($json.username ?? '').trim();\nconst userContent = String($json.userText ?? '').trim() || '[Leere Eingabe]';\n\n// Ollama-kompatible Messages (falls du später wieder umsteigst)\nconst messages = [\n  { role: 'system', content: systemText },\n  ...history,\n  { role: 'user', content: userContent },\n];\n\n// Für den AI Agent Node: Standardmäßig erwartet er das Feld \"chatInput\"\nconst chatParts = [];\nchatParts.push(systemText);\nif (userName) chatParts.push(`Du sprichst mit ${userName}.`);\nfor (const m of history) {\n  const role = m?.role === 'assistant' ? 'Assistant' : 'User';\n  const content = String(m?.content ?? '').trim();\n  if (content) chatParts.push(`${role}: ${content}`);\n}\nchatParts.push(`User: ${userContent}`);\n\nconst chatInput = chatParts.join('\\n');\n\nreturn [{\n  json: {\n    ...$json,\n    chatInput,\n    systemText,\n    ollamaModel: String($json.ollamaModel ?? 'llama3.2'),\n    ollamaMessages: messages,\n  }\n}];\n"
      },
      "name": "Build Ollama Messages",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2336,
        976
      ],
      "id": "6da3132a-fcab-49ee-9883-b4346502b25a"
    },
    {
      "parameters": {
        "mode": "combine",
        "combinationMode": "mergeByPosition",
        "options": {}
      },
      "name": "Merge Meta + OllamaResponse",
      "type": "n8n-nodes-base.merge",
      "typeVersion": 2,
      "position": [
        3040,
        752
      ],
      "id": "cc045e4a-3cc1-4624-ade5-42ec07ea216f"
    },
    {
      "parameters": {
        "jsCode": "const r = $json;\n\nlet assistantText = String(\n  r.assistantText ??\n  r.output ??\n  r.text ??\n  r.response?.text ??\n  r.message?.content ??\n  r.response ??\n  r.choices?.[0]?.message?.content ??\n  ''\n).trim();\n\nassistantText = assistantText\n  .replace(/<think>[\\s\\S]*?<\\/think>\\s*/gi, '')\n  .replace(/<think>[\\s\\S]*/gi, '')\n  .trim();\n\nreturn [{\n  json: {\n    ...r,\n    assistantText,\n  }\n}];"
      },
