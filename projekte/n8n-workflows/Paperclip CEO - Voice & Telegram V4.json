{
  "name": "Paperclip CEO - Voice & Telegram V4",
  "nodes": [
    {
      "parameters": {
        "jsCode": "const u = $input.first().json;\nconst msg = u.message ?? u.edited_message ?? u.channel_post ?? u.edited_channel_post ?? u;\n\nconst chatId = msg?.chat?.id ?? null;\nconst messageId = msg?.message_id ?? null;\n\nconst from = msg?.from ?? {};\nconst tgUserId = from?.id ?? null;\nconst firstName = from?.first_name ?? '';\nconst lastName = from?.last_name ?? '';\nconst tgUsername = from?.username ?? '';\nconst languageCode = from?.language_code ?? '';\nconst username = tgUsername || [firstName, lastName].filter(Boolean).join(' ') || 'Unbekannt';\n\n// Voice (Sprachnachricht) ODER Audio (Datei)\nconst voiceFileId = String(msg?.voice?.file_id || msg?.audio?.file_id || '').trim();\n\nconst inputType = voiceFileId ? 'voice' : 'text';\nconst userText = (msg?.text || msg?.caption || '').trim() || (voiceFileId ? '' : '[Leere Textnachricht]');\n\nreturn [{\n  json: {\n    source: 'telegram',\n    chatId,\n    messageId,\n    tgUserId,\n    firstName,\n    lastName,\n    tgUsername,\n    languageCode,\n    username,\n    inputType,\n    userText,\n    voiceFileId\n  }\n}];"
      },
      "name": "Normalize Telegram Input",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -368,
        480
      ],
      "id": "7e8941f0-cf30-4644-b299-4ebe88414c8c"
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "={{ (() => { const esc = s => String(s ?? '').split(\"'\").join(\"''\"); const chatId = Number($json.chatId) || 0; const tgUserId = Number($json.tgUserId) || 0; const username = esc($json.username); const firstName = esc($json.firstName); const lastName = esc($json.lastName); const tgUsername = esc($json.tgUsername); const languageCode = esc($json.languageCode); return \"WITH updated AS (UPDATE tg_chat_users SET \" +\"tg_user_id = \" + tgUserId + \", \" +\"username = '\" + username + \"', \" +\"first_name = '\" + firstName + \"', \" +\"last_name = '\" + lastName + \"', \" +\"tg_username = '\" + tgUsername + \"', \" +\"language_code = '\" + languageCode + \"', \" +\"last_seen_at = now() \" +\"WHERE chat_id = \" + chatId + \" RETURNING 1) \" +\"INSERT INTO tg_chat_users (tg_user_id, chat_id, username, first_name, last_name, tg_username, language_code, last_seen_at) \" +\"SELECT \" + tgUserId + \", \" + chatId + \", '\" + username + \"', '\" + firstName + \"', '\" + lastName + \"', '\" + tgUsername + \"', '\" + languageCode + \"', now() \" +\"WHERE NOT EXISTS (SELECT 1 FROM updated);\"; })() }}",
        "options": {}
      },
