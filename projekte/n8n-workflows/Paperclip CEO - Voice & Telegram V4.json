    {
      "parameters": {
        "jsCode": "const o = $json;\n\n// ElevenLabs STT kann je nach Version unterschiedlich heißen:\nconst transcript =\n  o.text ||\n  o.transcript ||\n  o.transcription ||\n  o.data?.text ||\n  o.data?.transcript ||\n  '';\n\nreturn [{\n  json: {\n    ...o,\n    userText: String(transcript || '').trim(),\n    inputType: 'voice'\n  }\n}];\n"
      },
      "name": "Set userText from STT",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        768,
        240
