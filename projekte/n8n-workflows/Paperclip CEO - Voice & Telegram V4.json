    {
      "parameters": {
        "jsCode": "const r = $json;\n\nlet assistantText = String(\n  r.assistantText ??\n  r.output ??\n  r.text ??\n  r.response?.text ??\n  r.message?.content ??\n  r.response ??\n  r.choices?.[0]?.message?.content ??\n  ''\n).trim();\n\nassistantText = assistantText\n  .replace(/<think>[\\s\\S]*?<\\/think>\\s*/gi, '')\n  .replace(/<think>[\\s\\S]*/gi, '')\n  .trim();\n\nreturn [{\n  json: {\n    ...r,\n    assistantText,\n  }\n}];"
      },
