{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "outputDirectory": "public",
  "installCommand": "pnpm install --frozen-lockfile",
  "buildCommand": "pnpm run build:vercel",
  "fluid": true,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api" },
    {
      "source": "/((?!api/)(?!assets/)(?!.*\\..*).*)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/index.mjs": {
      "maxDuration": 300,
      "memory": 3008
    }
  }
}
