{
  "name": "@valadrien-os/ui",
  "version": "0.3.1",
  "description": "Prebuilt ValAdrien OS board UI assets.",
  "license": "MIT",
  "homepage": "https://github.com/ValDola-stack/valadrien-os",
  "bugs": {
    "url": "https://github.com/ValDola-stack/valadrien-os/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ValDola-stack/valadrien-os",
    "directory": "ui"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "storybook": "storybook dev -p 6006 -c storybook/.storybook",
    "build-storybook": "storybook build -c storybook/.storybook -o storybook-static",
    "preview": "vite preview",
    "typecheck": "tsc -b",
    "clean": "rm -rf dist storybook-static tsconfig.tsbuildinfo",
    "prepack": "rm -f package.dev.json && cp package.json package.dev.json && node ../scripts/generate-ui-package-json.mjs",
    "postpack": "if [ -f package.dev.json ]; then mv package.dev.json package.json; fi"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@assistant-ui/react": "0.12.23",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@lexical/link": "0.35.0",
    "@mdxeditor/editor": "^3.52.4",
    "@radix-ui/react-slot": "^1.2.4",
    "@sentry/react": "^10.57.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/react-query": "^5.90.21",
    "@valadrien-os/adapter-acpx-local": "workspace:*",
    "@valadrien-os/adapter-claude-local": "workspace:*",
    "@valadrien-os/adapter-codex-local": "workspace:*",
    "@valadrien-os/adapter-cursor-cloud": "workspace:*",
    "@valadrien-os/adapter-cursor-local": "workspace:*",
    "@valadrien-os/adapter-gemini-local": "workspace:*",
    "@valadrien-os/adapter-grok-local": "workspace:*",
    "@valadrien-os/adapter-openclaw-gateway": "workspace:*",
    "@valadrien-os/adapter-opencode-local": "workspace:*",
    "@valadrien-os/adapter-pi-local": "workspace:*",
    "@valadrien-os/adapter-utils": "workspace:*",
    "@valadrien-os/shared": "workspace:*",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "hermes-paperclip-adapter": "^0.2.0",
    "i18next": "^26.1.0",
    "lexical": "0.35.0",
    "lucide-react": "^0.574.0",
    "mermaid": "^11.12.0",
    "posthog-js": "^1.386.6",
    "radix-ui": "^1.4.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-i18next": "^17.0.7",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.1.5",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.4.1"
  },
  "devDependencies": {
    "@sentry/vite-plugin": "^5.3.0",
    "@storybook/addon-a11y": "10.3.5",
    "@storybook/addon-docs": "10.3.5",
    "@storybook/react-vite": "10.3.5",
    "@tailwindcss/vite": "^4.0.7",
    "@types/node": "^25.2.3",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^4.3.4",
    "storybook": "10.3.5",
    "tailwindcss": "^4.0.7",
    "typescript": "^5.7.3",
    "vite": "^6.1.0",
    "vitest": "^3.0.5"
  }
}
