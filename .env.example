## Auth
# Generate: openssl rand -hex 32
BETTER_AUTH_SECRET=           # required
PAPERCLIP_PUBLIC_URL=http://localhost:3100  # required

## Agent JWT
# Generate: openssl rand -hex 32
PAPERCLIP_AGENT_JWT_SECRET=   # required
# PAPERCLIP_AGENT_JWT_AUDIENCE=
# PAPERCLIP_AGENT_JWT_ISSUER=
# PAPERCLIP_AGENT_JWT_TTL_SECONDS=

## Database
# Leave unset for embedded PGlite (local dev — zero setup)
# Set for external Postgres (production / Docker Compose)
# DATABASE_URL=postgres://user:password@host:5432/dbname

## Storage
# PAPERCLIP_STORAGE_PROVIDER=local  # local|s3 (default: local)
# PAPERCLIP_STORAGE_S3_BUCKET=
# PAPERCLIP_STORAGE_S3_REGION=
# PAPERCLIP_STORAGE_S3_ENDPOINT=

## Secrets
# PAPERCLIP_SECRETS_PROVIDER=env    # env|file (default: env)
# PAPERCLIP_SECRETS_MASTER_KEY=

## Deployment
# PAPERCLIP_DEPLOYMENT_MODE=local_trusted  # local_trusted|authenticated
# PAPERCLIP_DEPLOYMENT_EXPOSURE=private    # public|private

## Heartbeat
# HEARTBEAT_SCHEDULER_ENABLED=true
# HEARTBEAT_SCHEDULER_INTERVAL_MS=60000

## Backup
# PAPERCLIP_DB_BACKUP_ENABLED=false
# PAPERCLIP_DB_BACKUP_INTERVAL_MINUTES=60
# PAPERCLIP_DB_BACKUP_RETENTION_DAYS=7
# PAPERCLIP_DB_BACKUP_DIR=

## API Keys (for API key auth mode)
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

## Do NOT set these in Docker — already configured in docker-compose.yml
## Setting them here overrides container values and breaks things.
# PORT=3100
# SERVE_UI=true
# HOST=0.0.0.0
