DATABASE_URL=postgres://paperclip:paperclip@localhost:5432/paperclip
PORT=3100
SERVE_UI=false

# OpenClaw gateway auth token (from ~/.openclaw/openclaw.json → .gateway.auth.token)
OPENCLAW_GATEWAY_TOKEN=
OPENCLAW_GATEWAY_URL=ws://127.0.0.1:18789

# Telegram notifications for auth failures
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# OpenRouter API key for free model fallback (xiaomi/mimo-v2-pro, stepfun/step-3.5-flash:free)
OPENROUTER_API_KEY=
