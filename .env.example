# Required for Docker Compose (authenticated mode)
# Generate secrets: openssl rand -hex 32
BETTER_AUTH_SECRET=
PAPERCLIP_AGENT_JWT_SECRET=

# Public URL for auth callbacks and invite links
# For Tailscale: http://your-tailscale-hostname:3100
PAPERCLIP_PUBLIC_URL=http://localhost:3100

# Do NOT set these for Docker Compose — they are already configured in docker-compose.yml
# Setting them here will override container values and break things.
# DATABASE_URL=postgres://paperclip:paperclip@localhost:5432/paperclip
# PORT=3100
# SERVE_UI=false
