# --------------------------------------------------------------------
# Paperclip env example.
# Copy to .env (gitignored) for local dev, or set these in your hosting
# platform (Render dashboard, Fly secrets, etc.). Never commit real values.
# --------------------------------------------------------------------

# --- Core ---
DATABASE_URL=postgres://paperclip:paperclip@localhost:5432/paperclip
PORT=3100
HOST=0.0.0.0
SERVE_UI=true

# Required in any non-trusted-local mode. For local dev a static dev secret is
# fine; for any deployment generate 32+ random bytes (Render's
# `generateValue: true` does this automatically).
BETTER_AUTH_SECRET=paperclip-dev-secret

# --- Deployment mode ---
# local_trusted (default for laptop) | authenticated (for any shared/public host)
PAPERCLIP_DEPLOYMENT_MODE=local_trusted
# private (LAN/VPN/tailnet) | public (internet-facing)
PAPERCLIP_DEPLOYMENT_EXPOSURE=private
# Required when MODE=authenticated and EXPOSURE=public.
# PAPERCLIP_PUBLIC_URL=https://your-paperclip.example.com

# Optional Langfuse / HLT observability for heartbeat traces. Keep
# LANGFUSE_RECORD_IO off unless debugging; never log secrets into traces.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://us.cloud.langfuse.com
LANGFUSE_RECORD_IO=false

# Discord webhook for the daily merge digest (scripts/discord-daily-digest.sh)
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# --- Adapter wiring ---
#
# Most agent adapter config lives inside Paperclip's UI (Settings → Adapters
# Manager) rather than env vars, but a few external integrations expect creds
# in the environment when their adapter type is selected.
#
# Hint, not enforced: tag the source agent so dashboards stay readable.

# OpenClaw-HQ on Render (built-in adapter `openclaw_gateway`).
# OPENCLAW_GATEWAY_URL=wss://openclaw-hq.onrender.com/gateway
# OPENCLAW_TOKEN=

# Hermes (built-in adapter `hermes_local`).
# Install the Hermes CLI on this host: `pip install hermes-agent`.
# Provide at least one provider key the chosen Hermes profile expects, e.g.
# ANTHROPIC_API_KEY, OPENROUTER_API_KEY, OPENAI_API_KEY.
# HERMES_PROFILE=default

# OpenSwarm (built-in adapter `openswarm_local`, flavor `unohee` or `vrsen`).
# Install one (binaries collide, so pick per host):
#   npm install -g @intrect/openswarm    # unohee/OpenSwarm
#   npm install -g @vrsen/openswarm      # VRSEN/openswarm
# Provider auth via host env (or per-agent `env` config):
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# Optional, only for unohee daemon-mode features:
# LINEAR_API_KEY=
# DISCORD_TOKEN=
