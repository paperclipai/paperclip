DATABASE_URL=postgres://paperclip:paperclip@localhost:5432/paperclip
PORT=3100
SERVE_UI=false
BETTER_AUTH_SECRET=paperclip-dev-secret

# Bookforge runtime monitor
PAPERCLIP_BOOKFORGE_MONITOR_ENABLED=false
PAPERCLIP_BOOKFORGE_COMPANY_ID=2925a47a-961a-4212-8b36-ce711e2f6ec0
PAPERCLIP_BOOKFORGE_BASE_URL=http://127.0.0.1:5012
PAPERCLIP_BOOKFORGE_MONITOR_INTERVAL_MS=60000
# Optional exact-target guard. When set, Paperclip dispatches a critical wrong-book
# incident if Bookforge is spending on any other queue item. Leave blank when no
# Bookforge production target is approved.
PAPERCLIP_BOOKFORGE_APPROVED_TARGET_YAML=
PAPERCLIP_BOOKFORGE_APPROVED_TARGET_ITEM_ID=
PAPERCLIP_BOOKFORGE_APPROVED_TARGET_PROJECT=
PAPERCLIP_BOOKFORGE_APPROVED_TARGET_FILE=$HOME/.paperclip/bookforge-approved-target.json

# Discord webhook for daily merge digest (scripts/discord-daily-digest.sh)
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
