DATABASE_URL=postgres://paperclip:paperclip@localhost:5432/paperclip
PORT=3100
SERVE_UI=false
BETTER_AUTH_SECRET=paperclip-dev-secret

# Discord webhook for daily merge digest (scripts/discord-daily-digest.sh)
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# govbids pipeline
HIGHERGOV_API_KEY=
ANTHROPIC_API_KEY=
HUBSPOT_API_KEY=
BIDPRIME_API_TOKEN=

# govbids daily Slack notifier
# Create a Slack app, install to workspace, grab the Bot User OAuth Token (xoxb-…).
# Scopes required: chat:write, files:write, channels:read, groups:read.
# Invite the bot to the channel before running `govbids daily`.
SLACK_BOT_TOKEN=
SLACK_CHANNEL=
# Channel ID is needed because the bot doesn't have channels:read scope.
# To find it: run `pnpm govbids:slack-smoke` once — Slack echoes the ID back in the postMessage response.
SLACK_CHANNEL_ID=
# Optional. If set, the heartbeat alert (when ALL sources fail during a recovery run)
# is sent as a DM to this user instead of the channel. Get your member ID from Slack
# (profile → More → Copy member ID — looks like U0XXXXXXX).
SLACK_DM_USER_ID=

# BidPrime session — cookie-based. Daily run auto-includes BidPrime when both are set.
# Capture cookie: log in at bidprime.com → DevTools → Network → any authenticated request →
# copy the Cookie header value (one line, no "Cookie:" prefix) → save to BIDPRIME_SESSION_FILE.
# Find user ID: GET https://www.bidprime.com/api/v2/alerts/list with the cookie → userIds[0].
BIDPRIME_USER_ID=
BIDPRIME_SESSION_FILE=
