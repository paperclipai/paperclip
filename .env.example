# ============================================================================
# Upstream Paperclip (do NOT remove — required to boot)
# ============================================================================
DATABASE_URL=postgres://paperclip:paperclip@localhost:5432/paperclip
PORT=3100
SERVE_UI=false
BETTER_AUTH_SECRET=paperclip-dev-secret

# Discord webhook for daily merge digest (scripts/discord-daily-digest.sh)
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# ============================================================================
# Koenig customizations (see .env.example.koenig for full descriptions)
# ============================================================================

# LLM routing (the only LLM key strictly required for V1)
OPENROUTER_API_KEY=sk-or-v1-XXXXX_PASTE_REAL_KEY_HERE_XXXXX
XAI_API_KEY=xai-XXXXX_PASTE_REAL_KEY_HERE_XXXXX

# Research stack (free tiers OK)
TAVILY_API_KEY=
EXA_API_KEY=
FIRECRAWL_API_KEY=

# Content pipeline
CARTESIA_API_KEY=
RESEND_API_KEY=

# Koenig AI Academy product (the agency publishes to this)
ACADEMY_AGENT_API_KEY=
NEXT_PUBLIC_ACADEMY_CONVEX_URL=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET=koenig-academy-media
CLOUDFLARE_R2_ENDPOINT=

# Observability (Langfuse self-host on localhost:3200)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3200

# Phase 3 (Teams huddle) — leave blank for V1
RECALL_API_KEY=
ASSEMBLYAI_API_KEY=
MS_GRAPH_TENANT_ID=
MS_GRAPH_CLIENT_ID=
MS_GRAPH_CLIENT_SECRET=

# Watchdog alerting (Phase 2 — wire to Slack/Teams/Email)
WATCHDOG_ALERT_SLACK_WEBHOOK=
WATCHDOG_ALERT_EMAIL_TO=vardaan97@gmail.com
