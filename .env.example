DATABASE_URL=postgres://paperclip:paperclip@localhost:5432/paperclip
PORT=3100
SERVE_UI=false
BETTER_AUTH_SECRET=paperclip-dev-secret

# Discord webhook for daily merge digest (scripts/discord-daily-digest.sh)
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# Grace headroom above a hard budget cap before in-flight runs are also
# cancelled. Within [cap, cap*factor) an automatic hard-stop pauses the scope
# (blocks the next wake) but lets the current flow finish; past cap*factor it
# cancels running work. Default 1.25; set to 1.0 to disable grace.
# PAPERCLIP_BUDGET_HARDSTOP_GRACE_FACTOR=1.25
