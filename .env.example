DATABASE_URL=postgres://paperclip:paperclip@localhost:5432/paperclip
PORT=3100
SERVE_UI=false
BETTER_AUTH_SECRET=paperclip-dev-secret
PAPERCLIP_PUBLIC_APP_NAME=Brabrix Agent
VITE_PUBLIC_APP_NAME=Brabrix Agent

BRABRIX_API_URL=https://api.brabrix.com
BRABRIX_AGENT_TOKEN=
BRABRIX_PROJECT_ID=
BRABRIX_TENANT_ID=
BRABRIX_AGENT_ID=
# Optional (only set when your Brabrix API flow requires provider routing).
BRABRIX_PROVIDER=
# Optional endpoint overrides (defaults are already set in code).
BRABRIX_PROJECT_CONTEXT_ENDPOINT=
BRABRIX_NEXT_TASK_ENDPOINT=
BRABRIX_SEND_RUN_LOGS_ENDPOINT=
BRABRIX_COMPLETE_TASK_ENDPOINT=
BRABRIX_HTTP_TIMEOUT_MS=10000
BRABRIX_HTTP_MAX_RETRIES=2
BRABRIX_HTTP_RETRY_DELAY_MS=400

# Optional overrides for project import APIs (defaults follow Brabrix VSCode extension contract).
# BRABRIX_MEMBERSHIPS_ENDPOINT=/api/v1/me/memberships
# BRABRIX_LIST_PROJECTS_ENDPOINT=/api/v1/tenants/current/dev/projects
# BRABRIX_PROJECT_DETAIL_ENDPOINT=/api/v1/tenants/current/dev/projects/{projectId}
# BRABRIX_PROJECT_CONTEXT_EXPORT_ENDPOINT=/api/v1/tenants/current/dev/projects/{projectId}/export/context
# BRABRIX_PROJECT_BACKLOG_ENDPOINT=/api/v1/tenants/current/dev/projects/{projectId}/backlog
# BRABRIX_PROJECT_WORKFLOW_ENDPOINT=/api/v1/tenants/current/dev/projects/{projectId}/workflow
# BRABRIX_PROJECT_SKILLS_EXPORT_ENDPOINT=/api/v1/tenants/current/dev/projects/{projectId}/skills/export
# BRABRIX_PROJECT_SKILLS_ENDPOINT=/api/v1/tenants/current/dev/projects/{projectId}/skills

BRABRIX_SKILLHUB_API_URL=https://api.brabrix.com
BRABRIX_SKILLHUB_ENABLED=true
BRABRIX_SKILLHUB_TOKEN=
# Optional legacy fallback. Preferred: configure API key in Company Settings -> Brabrix (via Secrets).
BRABRIX_SKILLHUB_API_KEY=
BRABRIX_SKILLHUB_SEARCH_ENDPOINT=/api/public/dev-hub/items
BRABRIX_SKILLHUB_SKILL_DETAIL_ENDPOINT=/api/public/dev-hub/items/{skillId}
BRABRIX_SKILLHUB_CATEGORIES_ENDPOINT=/api/public/dev-hub/categories
BRABRIX_SKILLHUB_FEATURED_ENDPOINT=/api/public/dev-hub/featured
BRABRIX_SKILLHUB_HTTP_TIMEOUT_MS=10000
BRABRIX_SKILLHUB_HTTP_MAX_RETRIES=1
BRABRIX_SKILLHUB_HTTP_RETRY_DELAY_MS=350

# Discord webhook for daily merge digest (scripts/discord-daily-digest.sh)
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
