# Required: generate with `openssl rand -hex 32`
BETTER_AUTH_SECRET=
POSTGRES_PASSWORD=

# Connection string (uses POSTGRES_PASSWORD above in docker-compose)
DATABASE_URL=postgres://paperclip:${POSTGRES_PASSWORD}@db:5432/paperclip

# Server
PORT=18080
SERVE_UI=true

# Bug reporting (Linear integration)
# Create a Linear API key at: https://linear.app/settings/api
LINEAR_API_KEY=
LINEAR_TEAM_KEY=VALINT
