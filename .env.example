# =============================================================================
# Paperclip v2 Environment Variables
# Copy this file to .env and fill in the values for your environment.
# =============================================================================

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
DATABASE_URL=postgres://paperclip:paperclip@localhost:5432/paperclip

# Database backup settings
# PAPERCLIP_DB_BACKUP_ENABLED=true          # Enable/disable automatic DB backups
# PAPERCLIP_DB_BACKUP_INTERVAL_MINUTES=60   # Backup interval in minutes
# PAPERCLIP_DB_BACKUP_RETENTION_DAYS=30     # How many days to keep backups
# PAPERCLIP_DB_BACKUP_DIR=                  # Custom backup directory path

# Embedded Postgres (development only)
# PAPERCLIP_EMBEDDED_POSTGRES_VERBOSE=false # Verbose logging for embedded postgres

# Migration control
# PAPERCLIP_MIGRATION_PROMPT=never          # Skip migration prompts ("never" to disable)
# PAPERCLIP_MIGRATION_AUTO_APPLY=false      # Auto-apply pending migrations

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
PORT=3050
HOST=127.0.0.1
NODE_ENV=production
SERVE_UI=true                               # Serve the UI static files from the server

# PAPERCLIP_UI_DIR=../ui/dist              # Path to UI build output (for static serving)
# PAPERCLIP_UI_DEV_MIDDLEWARE=false         # Enable Vite dev middleware (development only)
# PAPERCLIP_OPEN_ON_LISTEN=false           # Open browser on server start
# PAPERCLIP_LOG_DIR=                       # Custom log directory path

# Runtime (set automatically by the server, rarely needed manually)
# PAPERCLIP_LISTEN_HOST=127.0.0.1          # Actual host the server bound to
# PAPERCLIP_LISTEN_PORT=3050               # Actual port the server bound to
# PAPERCLIP_API_URL=http://127.0.0.1:3050  # Full API URL

# Heartbeat scheduler
# HEARTBEAT_SCHEDULER_ENABLED=true                # Enable/disable heartbeat scheduler
# HEARTBEAT_SCHEDULER_INTERVAL_MS=30000           # Heartbeat check interval in ms

# Attachments
# PAPERCLIP_ALLOWED_ATTACHMENT_TYPES=             # Comma-separated allowed MIME types
# PAPERCLIP_ATTACHMENT_MAX_BYTES=10485760         # Max attachment size in bytes (default 10MB)

# Run/Operation log paths
# RUN_LOG_BASE_PATH=                              # Custom base path for run logs
# WORKSPACE_OPERATION_LOG_BASE_PATH=              # Custom base path for workspace operation logs

# -----------------------------------------------------------------------------
# Authentication / Security
# -----------------------------------------------------------------------------
# BETTER_AUTH_SECRET=                       # Auth secret (falls back to PAPERCLIP_AGENT_JWT_SECRET)
# BETTER_AUTH_TRUSTED_ORIGINS=              # Comma-separated trusted origins for CORS
# BETTER_AUTH_URL=                          # Better Auth base URL (legacy alias)
# BETTER_AUTH_BASE_URL=                     # Better Auth base URL (legacy alias)

# PAPERCLIP_PUBLIC_URL=                    # Public-facing URL (e.g. https://paperclip.greencatart.work)
# PAPERCLIP_AUTH_PUBLIC_BASE_URL=          # Public auth base URL (legacy, use PAPERCLIP_PUBLIC_URL)
# PAPERCLIP_AUTH_BASE_URL_MODE=            # Auth base URL resolution mode
# PAPERCLIP_AUTH_DISABLE_SIGN_UP=false     # Disable new user sign-up
# PAPERCLIP_ALLOWED_HOSTNAMES=             # Comma-separated allowed hostnames

# Agent JWT settings
# PAPERCLIP_AGENT_JWT_SECRET=              # JWT signing secret for agent auth
# PAPERCLIP_AGENT_JWT_TTL_SECONDS=172800   # JWT token TTL (default 48 hours)
# PAPERCLIP_AGENT_JWT_ISSUER=paperclip     # JWT issuer claim
# PAPERCLIP_AGENT_JWT_AUDIENCE=paperclip-api  # JWT audience claim

# Company management
# PAPERCLIP_ENABLE_COMPANY_DELETION=false  # Enable company deletion feature

# -----------------------------------------------------------------------------
# Deployment Mode
# -----------------------------------------------------------------------------
# PAPERCLIP_DEPLOYMENT_MODE=local_trusted  # Deployment mode: local_trusted, local_exposed, cloud
# PAPERCLIP_DEPLOYMENT_EXPOSURE=           # Deployment exposure setting

# -----------------------------------------------------------------------------
# Storage
# -----------------------------------------------------------------------------
# PAPERCLIP_STORAGE_PROVIDER=local_disk    # Storage provider: local_disk, s3
# PAPERCLIP_STORAGE_LOCAL_DIR=             # Local disk storage directory

# S3-compatible storage
# PAPERCLIP_STORAGE_S3_BUCKET=paperclip           # S3 bucket name
# PAPERCLIP_STORAGE_S3_REGION=us-east-1           # S3 region
# PAPERCLIP_STORAGE_S3_ENDPOINT=                  # S3 endpoint (for S3-compatible services)
# PAPERCLIP_STORAGE_S3_PREFIX=                     # Key prefix for S3 objects
# PAPERCLIP_STORAGE_S3_FORCE_PATH_STYLE=false     # Force path-style S3 URLs

# -----------------------------------------------------------------------------
# Secrets Management
# -----------------------------------------------------------------------------
# PAPERCLIP_SECRETS_PROVIDER=local_encrypted   # Secrets provider: local_encrypted, env, none
# PAPERCLIP_SECRETS_STRICT_MODE=false          # Strict mode for secrets (reject missing secrets)
# PAPERCLIP_SECRETS_MASTER_KEY=                # Inline master key for encryption (not recommended)
# PAPERCLIP_SECRETS_MASTER_KEY_FILE=           # Path to file containing the master key

# -----------------------------------------------------------------------------
# Instance / Data Directory
# -----------------------------------------------------------------------------
# PAPERCLIP_HOME=                          # Custom data directory for Paperclip
# PAPERCLIP_INSTANCE_ID=default            # Instance ID for multi-instance setups
# PAPERCLIP_CONFIG=                        # Path to config.json override
# PAPERCLIP_CONTEXT=                       # Path to context.json override
# PAPERCLIP_WORKSPACE_CWD=                 # Working directory for workspace operations

# Worktree support
# PAPERCLIP_IN_WORKTREE=false              # Whether running inside a worktree
# PAPERCLIP_WORKTREES_DIR=                 # Custom worktrees directory
# PAPERCLIP_WORKTREE_START_POINT=          # Git ref for worktree start point

# -----------------------------------------------------------------------------
# Agent Runtimes (API keys for local adapters)
# -----------------------------------------------------------------------------
# ANTHROPIC_API_KEY=                       # Anthropic API key (Claude adapter)
# OPENAI_API_KEY=                          # OpenAI API key (Codex/OpenCode adapters)
# GEMINI_API_KEY=                          # Google Gemini API key
# GOOGLE_API_KEY=                          # Google API key (alternative to GEMINI_API_KEY)
# GOOGLE_GENAI_USE_GCA=false              # Use Google Cloud AI for Gemini
# CURSOR_API_KEY=                          # Cursor API key

# Agent CLI paths
# PAPERCLIP_OPENCODE_COMMAND=              # Custom path to opencode CLI binary
# PAPERCLIP_PI_COMMAND=                    # Custom path to pi CLI binary
# CODEX_HOME=                              # Codex config home directory
# CLAUDE_HOME=                             # Claude config home directory
# CLAUDE_CONFIG_DIR=                       # Claude config directory

# Client connection (for CLI remote mode)
# PAPERCLIP_API_KEY=                       # API key for remote Paperclip server
# PAPERCLIP_COMPANY_ID=                    # Company ID for remote connection
# PAPERCLIP_SERVER_HOST=localhost           # Remote server host
# PAPERCLIP_SERVER_PORT=                    # Remote server port
