DATABASE_URL=postgres://paperclip:paperclip@localhost:5432/paperclip
PORT=3100
SERVE_UI=false
BETTER_AUTH_SECRET=paperclip-dev-secret

# Discord webhook for daily merge digest (scripts/discord-daily-digest.sh)
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# Eden AI gateway (https://api.edenai.run). OpenAI-compatible LLM router.
# Required when an opencode_local agent is configured to use Eden AI as
# its backend (see docs/adapters/edenai.md for setup). Paperclip itself
# does not read this value at runtime; it is forwarded into the spawned
# opencode child process, which uses it as the bearer token for Eden AI
# API calls. The base URL is set in OpenCode's global config, not here.
# EDENAI_API_KEY=
