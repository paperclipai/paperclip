# ── Agent Docker Integration ──────────────────────────────────────────
# Volume names created by claude-code-docker and opencode-docker.
# Run `docker volume ls` to find the exact names for your setup.
#
# The names follow the pattern: <compose-project>_<volume-name>
# Example: if your claude-code-docker project is "paperclip-claude-adi6ix",
#          the bin volume will be "paperclip-claude-adi6ix_claude-bin".

CLAUDE_BIN_VOLUME=claude-bin
CLAUDE_CONFIG_VOLUME=claude-config
OPENCODE_BIN_VOLUME=opencode-bin
OPENCODE_CONFIG_VOLUME=opencode-config

# ── API Keys ──────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Compose file list (uncomment to auto-load the agents overlay) ────
# COMPOSE_FILE=docker-compose.yml:docker-compose.agents.yml
