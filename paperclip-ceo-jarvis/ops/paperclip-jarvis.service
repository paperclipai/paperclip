[Unit]
Description=Paperclip CEO Jarvis API
After=network.target

[Service]
WorkingDirectory=/opt/paperclip-ceo-jarvis/backend
EnvironmentFile=/opt/paperclip-ceo-jarvis/.env
ExecStart=/opt/paperclip-ceo-jarvis/backend/.venv/bin/uvicorn app.main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=5
User=jarvis
Group=jarvis

[Install]
WantedBy=multi-user.target
